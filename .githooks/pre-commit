#!/usr/bin/env bash
#
# Reformats staged .java files with IntelliJ's command-line formatter using the
# repo's hmf_code_scheme.xml, so commits match the in-IDE style.
#
# One-time setup per clone:   git config core.hooksPath .githooks
# Skip a single commit:       git commit --no-verify
# Override the formatter:      export FORMAT_SH=/path/to/format.sh
#
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
scheme="$repo_root/hmf_code_scheme.xml"

# Staged Java files (added/copied/modified), NUL-safe (bash 3.2 compatible).
java_files=()
while IFS= read -r -d '' f; do
  java_files+=("$f")
done < <(git diff --cached --name-only --diff-filter=ACM -z -- '*.java')
[[ ${#java_files[@]} -eq 0 ]] && exit 0

# Resolve IntelliJ's format.sh.
format_sh="${FORMAT_SH:-}"
if [[ -z "$format_sh" ]]; then
  for candidate in \
    "/Applications/IntelliJ IDEA.app/Contents/bin/format.sh" \
    "/Applications/IntelliJ IDEA CE.app/Contents/bin/format.sh" \
    "$HOME/.local/share/JetBrains/Toolbox/apps/"*/*/bin/format.sh \
    /opt/intellij*/bin/format.sh; do
    [[ -x "$candidate" ]] && { format_sh="$candidate"; break; }
  done
fi

if [[ -z "$format_sh" || ! -x "$format_sh" ]]; then
  echo "pre-commit: IntelliJ format.sh not found; skipping formatting." >&2
  echo "            Set FORMAT_SH=/path/to/format.sh to enable." >&2
  exit 0
fi

# Absolute paths for the formatter.
abs_files=()
for f in "${java_files[@]}"; do
  abs_files+=("$repo_root/$f")
done

# Run with an isolated config/system dir so the formatter doesn't collide with
# an already-open IntelliJ ("Only one instance of IDEA can be run at a time").
# Cached under .git for warm-start speed.
hook_idea_dir="$(git rev-parse --git-path hmf-format-idea)"
mkdir -p "$hook_idea_dir"
hook_idea_dir="$(cd "$hook_idea_dir" && pwd)"
props="$hook_idea_dir/idea.properties"
printf 'idea.config.path=%s/config\nidea.system.path=%s/system\n' "$hook_idea_dir" "$hook_idea_dir" > "$props"
export IDEA_PROPERTIES="$props"

echo "pre-commit: formatting ${#abs_files[@]} Java file(s) with IntelliJ scheme..."
if ! "$format_sh" -s "$scheme" "${abs_files[@]}"; then
  echo "pre-commit: format.sh failed; commit with --no-verify to bypass." >&2
  exit 1
fi

# Re-stage anything the formatter touched.
for f in "${java_files[@]}"; do
  git add -- "$repo_root/$f"
done
